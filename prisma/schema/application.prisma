model Application {
  id             String   @id @default(uuid())
  userId         String?
  jobId          String
  name           String
  email          String
  resume_link    String
  cover_note     String?
  expectedSalary String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  job            Job      @relation(fields: [jobId], references: [id])
  user           User?    @relation(fields: [userId], references: [id])

  @@map("application")
}
