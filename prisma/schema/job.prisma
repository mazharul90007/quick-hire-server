model Job {
  id                    String         @id @default(uuid())
  userId                String
  categoryId            String
  title                 String
  companyName           String?
  companyLogo           String?
  companyDetails        String?
  location              String?
  district              String?
  vacancy               Int?
  age                   String?
  salary                String?
  experience            String?
  education             String?
  additionalReqirements String[]
  responsibilities      String[]
  requiredSkills        String[]
  description           String?
  benefits              String[]
  jobType               JobTypes       @default(ONSITE)
  employmentType        EmploymentType @default(FULL_TIME)
  tags                  String[]
  deadline              DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  applications          Application[]
  category              Category       @relation(fields: [categoryId], references: [id])
  user                  User           @relation(fields: [userId], references: [id])

  @@map("job")
}

enum JobTypes {
  REMOTE
  ONSITE
  HYBRID
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACTUAL
  INTERNSHIP
  FREELANCE
}
